{
  "groups": {
    "cn-group": {
      "type": "selector",
      "members": ["direct", "MATCH:🇨🇳", "MATCH:中国", "MATCH:cudy"],
      "default": "direct"
    },
    "hk-group": {
      "type": "selector",
      "members": ["direct", "MATCH:🇭🇰", "MATCH:香港"],
      "default": "direct"
    },
    "tw-group": {
      "type": "selector",
      "members": ["direct", "MATCH:🇹🇼", "MATCH:台湾"],
      "default": "direct"
    },
    "jp-group": {
      "type": "selector",
      "members": ["direct", "MATCH:🇯🇵", "MATCH:日本"],
      "default": "direct"
    },
    "sg-group": {
      "type": "selector",
      "members": ["direct", "MATCH:🇸🇬", "MATCH:新加坡", "MATCH:狮城"],
      "default": "direct"
    },
    "us-group": {
      "type": "selector",
      "members": ["direct", "MATCH:🇺🇸", "MATCH:美国"],
      "default": "direct"
    },
    "uk-group": {
      "type": "selector",
      "members": ["direct", "MATCH:🇬🇧", "MATCH:英国"],
      "default": "direct"
    },
    "de-group": {
      "type": "selector",
      "members": ["direct", "MATCH:🇩🇪", "MATCH:德国"],
      "default": "direct"
    },
    "nl-group": {
      "type": "selector",
      "members": ["direct", "MATCH:🇳🇱", "MATCH:荷兰"],
      "default": "direct"
    },

    "proxy": {
      "type": "selector",
      "members": [
        "direct",
        "auto",
        "cn-group",
        "hk-group",
        "tw-group",
        "jp-group",
        "sg-group",
        "us-group",
        "uk-group",
        "de-group",
        "nl-group",
        "ALL_NODES"
      ],
      "default": "auto"
    },

    "google-group": {
      "type": "selector",
      "members": ["hk-group", "tw-group", "jp-group", "sg-group", "us-group", "uk-group", "de-group", "nl-group", "proxy"],
      "default": "hk-group"
    },
    "youtube-group": {
      "type": "selector",
      "members": ["hk-group", "tw-group", "jp-group", "sg-group", "us-group", "uk-group", "de-group", "nl-group", "proxy"],
      "default": "hk-group"
    },
    "ai-group": {
      "type": "selector",
      "members": ["us-group", "sg-group", "jp-group", "hk-group", "tw-group", "uk-group", "de-group", "nl-group", "proxy"],
      "default": "us-group"
    },
    "spotify-group": {
      "type": "selector",
      "members": ["hk-group", "tw-group", "jp-group", "sg-group", "us-group", "uk-group", "de-group", "nl-group", "proxy"],
      "default": "hk-group"
    },
    "telegram-group": {
      "type": "selector",
      "members": ["sg-group", "hk-group", "tw-group", "jp-group", "us-group", "uk-group", "de-group", "nl-group", "proxy"],
      "default": "sg-group"
    },
    "finance-group": {
      "type": "selector",
      "members": ["hk-group", "sg-group", "uk-group", "us-group", "de-group", "nl-group", "proxy"],
      "default": "hk-group"
    },
    "streaming-group": {
      "type": "selector",
      "members": ["hk-group", "tw-group", "jp-group", "sg-group", "us-group", "uk-group", "de-group", "nl-group", "proxy"],
      "default": "hk-group"
    },
    "social-group": {
      "type": "selector",
      "members": ["hk-group", "tw-group", "jp-group", "sg-group", "us-group", "uk-group", "de-group", "nl-group", "proxy"],
      "default": "hk-group"
    }
  },

